        {
          "name": "PUT /shipments/:id/deliver - Deliver Shipment (Success)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{JWT_TOKEN}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{LOGISTICS_SERVICE_URL}}/shipments/{{SHIPMENT_ID}}/deliver",
              "host": ["{{LOGISTICS_SERVICE_URL}}"],
              "path": ["shipments", "{{SHIPMENT_ID}}", "deliver"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Set shipment to OutForDelivery first",
                  "pm.sendRequest({",
                  "  url: '{{LOGISTICS_SERVICE_URL}}/shipments/{{SHIPMENT_ID}}/status',",
                  "  method: 'PUT',",
                  "  header: {",
                  "    'Authorization': 'Bearer {{JWT_TOKEN}}',",
                  "    'Content-Type': 'application/json'",
                  "  },",
                  "  body: {",
                  "    mode: 'raw',",
                  "    raw: JSON.stringify({ status: 'OutForDelivery' })",
                  "  }",
                  "}, (err, res) => {",
                  "  if (err) console.error(err);",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Shipment status updated to Delivered', () => {",
                  "  const response = pm.response.json();",
                  "  pm.expect(response._id).to.equal('{{SHIPMENT_ID}}');",
                  "  pm.expect(response.status).to.equal('Delivered');",
                  "  pm.expect(response.actualDeliveryDate).to.exist;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
