  "item": [
    {
      "name": "Shipment APIs",
      "item": [
        {
          "name": "POST /shipments - Create Shipment (Success)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{JWT_TOKEN}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"orderId\":\"{{ORDER_ID}}\",\"packageId\":\"{{PACKAGE_ID}}\",\"carrier\":\"DefaultCarrier\",\"serviceLevel\":\"Standard\",\"deliveryAddress\":{\"street\":\"123 Main St\",\"city\":\"New York\",\"state\":\"NY\",\"zipCode\":\"10001\",\"country\":\"USA\"},\"notes\":\"Test shipment\"}"
            },
            "url": {
              "raw": "{{LOGISTICS_SERVICE_URL}}/shipments",
              "host": ["{{LOGISTICS_SERVICE_URL}}"],
              "path": ["shipments"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', () => {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Response has shipment ID and tracking number', () => {",
                  "  const response = pm.response.json();",
                  "  pm.expect(response._id).to.be.a('string');",
                  "  pm.expect(response.trackingNumber).to.match(/^TRK-/);",
                  "  pm.expect(response.qrCode).to.match(/^QR-/);",
                  "  pm.expect(response.orderId).to.equal('{{ORDER_ID}}');",
                  "  pm.expect(response.packageId).to.equal('{{PACKAGE_ID}}');",
                  "  pm.expect(response.status).to.equal('Created');",
                  "  pm.expect(response.deliveryAddress).to.have.all.keys('street', 'city', 'state', 'zipCode', 'country');",
                  "});",
                  "pm.environment.set('SHIPMENT_ID', pm.response.json()._id);",
                  "pm.environment.set('TRACKING_NUMBER', pm.response.json().trackingNumber);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
