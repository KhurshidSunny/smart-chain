                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"orderId\": \"{{ORDER_ID}}\",\n  \"orderNumber\": \"ORD-{{ORDER_ID}}\",\n  \"items\": [\n    {\n      \"productId\": \"{{PRODUCT_ID}}\",\n      \"sku\": \"SKU123\",\n      \"name\": \"Test Product\",\n      \"quantity\": 2,\n      \"location\": \"Aisle 1\"\n    }\n  ]\n}"
                        },
                        "url": {
                            "raw": "{{WAREHOUSE_SERVICE_URL}}/picking-lists",
                            "host": [
                                "{{WAREHOUSE_SERVICE_URL}}"
                            ],
                            "path": [
                                "picking-lists"
                            ]
                        }
                    },
                    "response": [],
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status code is 201', function () {",
                                    "    pm.response.to.have.status(201);",
                                    "});",
                                    "pm.test('Response has pickingListId', function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData._id).to.be.a('string');",
                                    "    pm.collectionVariables.set('pickingListId', jsonData._id);",
                                    "    pm.collectionVariables.set('itemId', jsonData.items[0]._id);",
                                    "});",
                                    "pm.test('Response matches schema', function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.orderId).to.equal('{{ORDER_ID}}');",
                                    "    pm.expect(jsonData.orderNumber).to.equal('ORD-{{ORDER_ID}}');",
                                    "    pm.expect(jsonData.status).to.equal('Pending');",
                                    "    pm.expect(jsonData.items).to.be.an('array').that.has.lengthOf(1);",
                                    "    pm.expect(jsonData.items[0].sku).to.equal('SKU123');",
                                    "});"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ]
